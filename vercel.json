{
  "version": 2,
  "functions": {
    "api/surah.js": {
      "runtime": "@vercel/node"
    }
  },
  "routes": [
    {
      "src": "/api/surah",
      "dest": "/api/surah.js"
    },
    {
      "src": "/data/(.*)",
      "dest": "/data/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
